{
  "Jwt": {
    "Issuer": "your-platform",
    "Audience": "claude-mcp",
    "SecretKey": "CHANGE_ME_MIN_32_CHARACTERS_LONG!!",
    "ExpiryMinutes": 60,
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7,
    "ClaudeTokenExpiryDays": 30
  },
  "GitHub": {
    "ClientId": "YOUR_GITHUB_OAUTH_CLIENT_ID",
    "ClientSecret": "YOUR_GITHUB_OAUTH_CLIENT_SECRET",
    "RedirectUri": "https://flatplanet-api.azurewebsites.net/api/auth/oauth/github/callback",
    "FrontendCallbackUrl": "https://your-app.com/auth/callback"
  },
  "Encryption": {
    "Key": "CHANGE_ME_32_CHAR_AES_KEY_HERE!!"
  },
  "Supabase": {
    "Host": "aws-0-us-east-1.pooler.supabase.com",
    "Port": 6543,
    "Database": "postgres",
    "AdminUser": "postgres.YOUR_PROJECT_REF",
    "AdminPassword": "YOUR_SUPABASE_DB_PASSWORD"
  },
  "AllowedSchemaPrefix": "project_",
  "Cors": {
    "AllowedOrigins": []
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
